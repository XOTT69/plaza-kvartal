rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/admin_emails/$(request.auth.token.email));
    }

    match /buildings/{buildingId} {
      // Дозволяємо читати без авторизації (список будинків на сторінці входу)
      allow read: if true;
      allow write: if isAdmin();
    }

    match /apartments/{aptId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /announcements/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /contacts/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /events/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /polls/{id} {
      allow read: if isAuth();
      allow create, delete: if isAdmin();
      allow update: if isAuth();
    }

    match /neighborPosts/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    match /issues/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    match /admin_emails/{email} {
      // Будь-який auth-користувач може читати (для перевірки першого входу)
      // Write — тільки admin або сам собі (для першого Google входу)
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.token.email == email;
      allow update, delete: if isAdmin();
    }
  }
}